generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String              @id @default(cuid())
  email          String              @unique
  displayName    String?
  reputation     Int                 @default(0)
  createdAt      DateTime            @default(now())
  favoriteEvents UserFavoriteEvent[]
  favoritePlaces UserFavoritePlace[]
  preferences    UserPreference?
  visits         UserVisit[]
}

/// Пользовательские предпочтения (включая "НЕ интересно")
model UserPreference {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  /// категории, которые НЕ интересны пользователю
  excludedCategorySlugs  String[]
  /// интересующие категории (опционально)
  preferredCategorySlugs String[]
  user                   User     @relation(fields: [userId], references: [id])
}

model UserFavoritePlace {
  id        String   @id @default(cuid())
  userId    String
  placeId   String
  createdAt DateTime @default(now())
  place     Place    @relation(fields: [placeId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, placeId])
  @@index([userId])
  @@index([placeId])
}

model UserFavoriteEvent {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, eventId])
  @@index([userId])
  @@index([eventId])
}

model UserVisit {
  id        String   @id @default(cuid())
  userId    String
  placeId   String?
  eventId   String?
  visitedAt DateTime @default(now())
  note      String?
  event     Event?   @relation(fields: [eventId], references: [id])
  place     Place?   @relation(fields: [placeId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([placeId])
  @@index([eventId])
}

model Category {
  id     String          @id @default(cuid())
  name   String
  /// англ. название (RU/EN фаза 2); null → показываем русское
  nameEn String?
  slug   String          @unique
  order  Int             @default(0)
  places PlaceCategory[]
}

model PlaceCategory {
  placeId    String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])
  place      Place    @relation(fields: [placeId], references: [id])

  @@id([placeId, categoryId])
}

model AmenityGroup {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  amenities Amenity[]
}

model Amenity {
  id         String         @id @default(cuid())
  name       String
  nameEn     String?
  slug       String         @unique
  groupId    String
  group      AmenityGroup   @relation(fields: [groupId], references: [id])
  placeLinks PlaceAmenity[]
}

model PlaceAmenity {
  placeId   String
  amenityId String
  amenity   Amenity @relation(fields: [amenityId], references: [id])
  place     Place   @relation(fields: [placeId], references: [id])

  @@id([placeId, amenityId])
}

model AgeGroup {
  id     String          @id @default(cuid())
  name   String
  nameEn String?
  minAge Int
  maxAge Int
  places PlaceAgeGroup[]

  /// диапазон возраста уникален — не плодим дубли «3–6 лет» (нужно для idempotent upsert в seed)
  @@unique([minAge, maxAge])
}

model PlaceAgeGroup {
  placeId    String
  ageGroupId String
  ageGroup   AgeGroup @relation(fields: [ageGroupId], references: [id])
  place      Place    @relation(fields: [placeId], references: [id])

  @@id([placeId, ageGroupId])
}

model PlaceSchedule {
  id        String    @id @default(cuid())
  placeId   String
  day       DayOfWeek
  openTime  String
  closeTime String
  isClosed  Boolean   @default(false)
  place     Place     @relation(fields: [placeId], references: [id])

  /// один интервал на (место, день, время открытия): разрешает обед/2 окна, но запрещает дубль
  @@unique([placeId, day, openTime])
}

/// доп. фото места для мини-галереи (обложка живёт отдельно в Place.imageUrl)
/// МЕДИА-ПРАВА: у каждого фото фиксируем источник и основание использования —
/// авторское право у того, кто снял; чужой контент без согласия не публикуем
/// (критично для семейного бренда). null-поля = провенанс не зафиксирован
/// (старые записи); для новых фото заполнять source + rightsNote.
model PlacePhoto {
  id         String           @id @default(cuid())
  placeId    String
  url        String
  caption    String?
  order      Int              @default(0)
  /// кто источник фото: своё / от владельца места / от родителя-контрибьютора
  source     PhotoSourceType?
  /// автор снимка (имя или бренд), если известен
  author     String?
  /// основание использования: «фото Вероники», «согласие владельца в LINE,
  /// 2026-07-15» и т.п. — одна строка-провенанс для юридической чистоты
  rightsNote String?
  place      Place            @relation(fields: [placeId], references: [id])

  @@index([placeId])
}

model PlacePricing {
  id        String          @id @default(cuid())
  placeId   String
  priceType PriceType
  audience  PricingAudience
  minPrice  Float?
  maxPrice  Float?
  currency  String
  place     Place           @relation(fields: [placeId], references: [id])
}

/// Тарифы входа таблицей «длительность × ребёнок/взрослый» (детские игровые-кафе
/// вроде LariDea: 1/3/5 часов, отдельная цена ребёнку и взрослому). Отдельно от
/// PlacePricing (та — единый/диапазонный вход + Thai-price по аудитории).
model PlaceEntryPrice {
  id         String @id @default(cuid())
  placeId    String
  /// подпись строки: «1 час», «3 часа», «Разовый вход»
  label      String
  labelEn    String?
  childPrice Float?
  adultPrice Float?
  currency   String @default("THB")
  order      Int    @default(0)
  place      Place  @relation(fields: [placeId], references: [id])

  @@index([placeId])
}

/// Справочник категорий занятий (плавание, рисование…). Справочник + M:N, НЕ
/// enum: набор растёт (робототехника, шахматы…) без миграции, как языки/каналы;
/// занятие бывает в нескольких категориях (развивашка = раннее развитие + музыка).
model ActivityCategory {
  id       String                    @id @default(cuid())
  slug     String                    @unique
  name     String
  nameEn   String?
  order    Int                       @default(0)
  programs ProgramActivityCategory[]
}

model ProgramActivityCategory {
  programId  String
  categoryId String
  category   ActivityCategory @relation(fields: [categoryId], references: [id])
  program    PlaceProgram     @relation(fields: [programId], references: [id])

  @@id([programId, categoryId])
}

/// Программы места: лагеря, абонементы, курсы. У многих мест цена живёт именно
/// здесь (напр. у детских кафе разовый вход не публикуют — только абонементы).
/// type — enum: категории программ универсальны и конечны, не зависят от страны
/// (в отличие от языков/каналов). Даты — для сезонных программ (лагерь).
model PlaceProgram {
  id          String      @id @default(cuid())
  /// место занятия: ЛИБО каталожное (placeId/place), ЛИБО текстовое
  /// (venueName/venueAddress) — для развивашек в садах без своей страницы места
  placeId     String?
  /// slug для собственной страницы занятия (`/activities/[slug]`). Есть только
  /// у COURSE/CAMP (у абонементов страницы нет → null). Пока глобально уникален
  /// (slug'и префиксуем местом); при мультирегион-масштабе → city-scoped.
  slug        String?     @unique
  type        ProgramType
  name        String
  nameEn      String?
  description String?
  descriptionEn String?
  /// обложка занятия (путь в public); null = нет фото
  imageUrl    String?
  price       Float?
  /// зачёркнутая «старая» цена для акций (напр. абонемент со скидкой)
  oldPrice    Float?
  currency    String      @default("THB")
  /// подпись к цене: «/неделя», «/30 дней», «за ребёнка»
  priceUnit   String?
  priceUnitEn String?
  /// возраст занятия В МЕСЯЦАХ (чтобы малыши 4 мес не терялись в «годах»);
  /// нужен для фильтра «что подходит моему ребёнку N лет»
  minAgeMonths Int?
  maxAgeMonths Int?
  startDate   DateTime?
  endDate     DateTime?
  order       Int         @default(0)
  place       Place?      @relation(fields: [placeId], references: [id])
  categories  ProgramActivityCategory[]
  classes     PlaceClass[]
  /// текстовое место проведения (когда нет каталожного place — напр. сад)
  venueName    String?
  venueNameEn  String?
  venueAddress String?
  /// Демо-запись (см. Place.isDemo)
  isDemo      Boolean     @default(false)
  /// город занятия для scoping БЕЗместных занятий (у place-занятий — из place)
  cityId      String?
  city        City?       @relation(fields: [cityId], references: [id])

  @@index([placeId])
  @@index([cityId])
}

/// Возрастные классы внутри программы (напр. 8 классов гимнастики Little Gym):
/// показываются таблицей на странице занятия, лента остаётся одной карточкой.
/// parentRequired: true = с родителем (red, 45 мин), false = без (blue, 1 ч),
/// null = оба варианта (переходный возраст).
model PlaceClass {
  id             String       @id @default(cuid())
  programId      String
  name           String
  /// человекочитаемый возраст с постера («4–10 мес», «5–6 лет»)
  ageLabel       String
  ageLabelEn     String?
  minAgeMonths   Int
  maxAgeMonths   Int
  parentRequired Boolean?
  /// недельное расписание строкой: «Вт 11:00 · Ср 11:00 · Чт 15:00…»
  schedule       String
  scheduleEn     String?
  order          Int          @default(0)
  program        PlaceProgram @relation(fields: [programId], references: [id])

  @@index([programId])
}

/// Контакты места: телефон/сайт/соцсети. type — канал строкой (phone, website,
/// instagram, facebook, line, whatsapp…), НЕ enum — новые каналы (LINE в Азии
/// и т.п.) добавляются без миграции, как и для языков (мультирегион).
model PlaceContact {
  id      String @id @default(cuid())
  placeId String
  type    String
  value   String
  order   Int    @default(0)
  place   Place  @relation(fields: [placeId], references: [id])

  @@index([placeId])
}

/// «Полезно знать»: короткие практические советы места — ответы на вопросы
/// родителей из чатов (носки, залог, сменка, свой перекус…). topic — slug-тема
/// («socks», «prices»…) для будущей группировки или подъёма темы до фильтра.
model PlaceTip {
  id         String    @id @default(cuid())
  placeId    String
  text       String
  textEn     String?
  topic      String?
  order      Int       @default(0)
  /// когда факт последний раз подтверждён (доверие: показываем свежесть;
  /// null = дата проверки неизвестна, подпись не выводится)
  verifiedAt DateTime?
  place      Place     @relation(fields: [placeId], references: [id])

  @@index([placeId])
}

model PlaceBirthdayInfo {
  id              String   @id @default(cuid())
  placeId         String   @unique
  hasPackages     Boolean
  minGuests       Int?
  maxGuests       Int?
  /// tri-state: true/false/null=«уточняется» (как признаки Place)
  depositRequired Boolean?
  preBookingDays  Int?
  notes           String?
  notesEn         String?
  lastUpdatedAt   DateTime @updatedAt
  place           Place    @relation(fields: [placeId], references: [id])
}

/// Справочник языков персонала (ISO-код, напр. th/en). Справочник, а не enum —
/// enum ломал бы мультирегион (миграция на каждую новую страну).
model Language {
  id         String               @id @default(cuid())
  code       String               @unique
  name       String
  nameEn     String?
  placeLinks PlaceStaffLanguage[]
}

model PlaceStaffLanguage {
  placeId    String
  languageId String
  language   Language @relation(fields: [languageId], references: [id])
  place      Place    @relation(fields: [placeId], references: [id])

  @@id([placeId, languageId])
}

/// ПРАВИЛО роста признаков места (чтобы модель оставалась единообразной):
///  • простой «да/нет» (кондиционер, парковка) → булева колонка прямо здесь;
///  • значение из набора (языки персонала, категории) → отдельный справочник + M:N;
///  • группа связанных полей (детское кафе, день рождения) → отдельная 1:1-модель.
model Place {
  id                 String              @id @default(cuid())
  name               String
  slug               String
  description        String?
  descriptionEn      String?
  /// обложка места (путь в public, напр. /images/places/laridea.jpg); null = нет фото
  imageUrl           String?
  address            String
  latitude           Float
  longitude          Float
  /// проверенная ссылка на КАРТОЧКУ места в Google Maps (с фото/отзывами/часами);
  /// приоритетнее координат — координаты дают лишь голую метку на карте
  googleMapsUrl      String?
  /// PROVENANCE (движок данных): канонический Google Place ID (формат ChIJ…) —
  /// ключ дедупа при импорте: одно и то же заведение не занесётся дважды.
  /// null = место занесено вручную без привязки к Google
  googlePlaceId      String?             @unique
  /// откуда взялась запись: ручной занос / импорт движком / UGC / бизнес.
  /// Симметрично Event.sourceType; текущий каталог занесён вручную → ADMIN
  sourceType         PlaceSourceType     @default(ADMIN)
  /// права на обложку (imageUrl): кто снял / на каком основании используем
  /// (напр. «фото Вероники, июль 2026»). null = провенанс не зафиксирован
  imageRightsNote    String?
  /// подпись под таблицей входа (PlaceEntryPrice): скидки, НДС и т.п.
  entryPriceNote     String?
  entryPriceNoteEn   String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  /// Признаки-факты о месте — nullable (три состояния): true = есть,
  /// false = точно нет, null = ещё не проверяли («уточняется»). Не подменяем
  /// пробел в данных уверенным «нет» — это подрывает доверие к гиду.
  animalContact      Boolean?
  canLeaveChild      Boolean?
  /// возраст (в месяцах), с которого можно оставить ребёнка под присмотром;
  /// осмыслен при canLeaveChild=true (иначе не показываем). null = порог не уточнён
  leaveChildFromMonths Int?
  hasFood            Boolean?
  hasWifi            Boolean?
  indoor             Boolean             @default(false)
  outdoor            Boolean             @default(false)
  /// Умные фильтры (Эпик 4): признаки удобства для родителя-удалёнщика (тоже tri-state)
  hasAirCon          Boolean?
  hasParking         Boolean?
  hasCafeSeating     Boolean?
  hasPowerOutlets    Boolean?
  /// Сценарий «Спрятаться от жары/дождя»: укрыться можно не только в коробке с
  /// кондиционером. Открытая площадка с навесами (тень + не мочит дождь) и
  /// вентиляторами укрывает не хуже (напр. Pa Boon Cafe). tri-state.
  hasCoveredArea     Boolean?
  hasFans            Boolean?
  createdByUserId    String?
  isAnonymous        Boolean             @default(false)
  /// Демо-запись для локальной разработки: публичные выборки скрывают её,
  /// если не включён SHOW_DEMO (см. src/lib/demo/show-demo.ts)
  isDemo             Boolean             @default(false)
  /// МОДЕРАЦИЯ + UGC
  status             PlaceStatus         @default(PENDING)
  events             Event[]
  ageGroups          PlaceAgeGroup[]
  amenities          PlaceAmenity[]
  birthdayInfo       PlaceBirthdayInfo?
  categories         PlaceCategory[]
  contacts           PlaceContact[]
  pricing            PlacePricing[]
  entryPrices        PlaceEntryPrice[]
  photos             PlacePhoto[]
  programs           PlaceProgram[]
  schedules          PlaceSchedule[]
  staffLanguages     PlaceStaffLanguage[]
  tips               PlaceTip[]
  userFavoritePlaces UserFavoritePlace[]
  userVisits         UserVisit[]
  /// ГЕО (Сессия 2): город места обязателен — место всегда физически где-то
  cityId             String
  city               City                @relation(fields: [cityId], references: [id])

  @@unique([cityId, slug])
  @@index([cityId, status])
}

model EventCategory {
  id    String              @id @default(cuid())
  name  String
  nameEn String?
  slug  String              @unique
  links EventCategoryLink[]
}

model EventCategoryLink {
  eventId    String
  categoryId String
  category   EventCategory @relation(fields: [categoryId], references: [id])
  event      Event         @relation(fields: [eventId], references: [id])

  @@id([eventId, categoryId])
}

model Event {
  id                 String              @id @default(cuid())
  title              String
  titleEn            String?
  slug               String
  description        String?
  descriptionEn      String?
  /// обложка события (путь в public); null = нет фото
  imageUrl           String?
  /// ДАТЫ (поддержка однодневных, многодневных и recurring)
  startDate          DateTime
  endDate            DateTime?
  /// ЛОКАЦИЯ (может существовать без Place)
  locationName       String?
  locationNameEn     String?
  address            String?
  latitude           Float?
  longitude          Float?
  /// ОПЦИОНАЛЬНАЯ связь с Place (ВАЖНОЕ РЕШЕНИЕ)
  placeId            String?
  /// UGC + МОДЕРАЦИЯ
  status             EventStatus         @default(PENDING)
  sourceType         EventSourceType     @default(USER)
  createdByUserId    String?
  isAnonymous        Boolean             @default(false)
  /// AI & Review (вариант B)
  aiScore            Float?
  aiFlags            String?
  reviewNotes        String?
  approvedAt         DateTime?
  /// ЖИЗНЕННЫЙ ЦИКЛ (автоархив)
  autoArchive        Boolean             @default(true)
  archivedAt         DateTime?
  /// МОНОТИЗАЦИЯ (на будущее)
  isFeatured         Boolean             @default(false)
  isSponsored        Boolean             @default(false)
  /// CLAIM БИЗНЕСОМ
  isClaimed          Boolean             @default(false)
  organizerName      String?
  organizerContact   String?
  /// Демо-запись (см. Place.isDemo)
  isDemo             Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  place              Place?              @relation(fields: [placeId], references: [id])
  categories         EventCategoryLink[]
  userFavoriteEvents UserFavoriteEvent[]
  userVisits         UserVisit[]
  /// ГЕО (Сессия 2): город события nullable — событие может быть онлайн/без города
  cityId             String?
  city               City?               @relation(fields: [cityId], references: [id])

  @@unique([cityId, slug])
  @@index([placeId])
  @@index([cityId, status])
  @@index([status])
  @@index([startDate])
  @@index([endDate])
}

/// ГЕОГРАФИЯ (мультирегион): страна → город. Region пока не нужен.
model Country {
  id        String   @id @default(cuid())
  iso2      String   @unique
  name      String
  /// дефолт валюты для формы (НЕ источник истины — цена хранит свою валюту)
  currency  String?
  createdAt DateTime @default(now())
  cities    City[]
}

model City {
  id             String   @id @default(cuid())
  slug           String
  name           String
  nameEn         String?
  seoDescription String?
  seoDescriptionEn String?
  latitude       Float?
  longitude      Float?
  timezone       String
  /// город виден в поиске/выдаче только когда наполнен (SEO-гейт)
  isPublished    Boolean  @default(false)
  countryId      String
  country        Country  @relation(fields: [countryId], references: [id])
  places         Place[]
  events         Event[]
  programs       PlaceProgram[]
  createdAt      DateTime @default(now())

  @@unique([countryId, slug])
}

enum PriceType {
  FREE
  PAID
  MIXED
}

enum PricingAudience {
  GENERAL
  THAI_ID
  THAI_DL
  EXPAT
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

enum EventStatus {
  PENDING
  APPROVED
  REJECTED
  AUTO_APPROVED
  ARCHIVED
}

enum PlaceStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProgramType {
  CAMP
  MEMBERSHIP
  COURSE
}

enum EventSourceType {
  USER
  ADMIN
  BUSINESS
  IMPORT
}

/// источник записи места (симметрично EventSourceType):
/// ADMIN — ручной занос командой; IMPORT — движок данных (Google Places API);
/// USER/BUSINESS — задел под UGC и claim бизнесом
enum PlaceSourceType {
  USER
  ADMIN
  BUSINESS
  IMPORT
}

/// источник фото (медиа-права): OWN — снято нами (Вероникой/командой),
/// PLACE_OWNER — прислано самим местом с его согласия,
/// CONTRIBUTOR — прислано родителем с согласия на публикацию.
/// Чужие фото из Google/Instagram НЕ сохраняем — только показ с атрибуцией
/// через официальные API, без копирования в нашу галерею.
enum PhotoSourceType {
  OWN
  PLACE_OWNER
  CONTRIBUTOR
}

/// Журнал публикаций в Telegram-канал: что уже отправлено (защита от дублей).
/// Отдельная модель без relations — интеграция не трогает основные модели.
model TelegramPost {
  id         String             @id @default(cuid())
  entityType TelegramPostEntity
  entityId   String
  /// message_id поста в канале (для будущего редактирования); null = запись
  /// сделана без отправки (baseline)
  messageId  Int?
  /// канал, куда ушёл пост (@pattayakidsguide) — на случай смены канала
  channelId  String
  postedAt   DateTime           @default(now())

  @@unique([entityType, entityId])
}

enum TelegramPostEntity {
  EVENT
  PLACE
}
