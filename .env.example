# Скопируйте в .env и заполните. Сам .env не коммитится.

# PostgreSQL (пул соединений). Без кавычек.
DATABASE_URL=postgresql://user:password@host/db

# Показывать [Демо]-контент (демо-место/события/занятие).
# Локально для разработки — "true"; на публичном деплое НЕ задавать
# (по умолчанию демо скрыто, прямые URL демо отдают 404).
SHOW_DEMO="true"

# База публичных URL для sitemap/robots (на деплое — реальный домен).
# Необязательно локально: по умолчанию http://localhost:3000.
# NEXT_PUBLIC_SITE_URL=https://example.com

# Движок данных: импорт скелета мест из Google Places API (npm run import:place).
# Нужен только для импорта; сайт без него работает. Как получить ключ и
# сколько это стоит — docs/DATA_ENGINE.md.
# GOOGLE_PLACES_API_KEY=
