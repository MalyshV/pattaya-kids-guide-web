{
  "name": "pattaya-kids-guide-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gaps": "tsx prisma/gaps.ts",
    "check": "npm run lint && npm run typecheck && npm run test",
    "fix": "npm run format && npm run lint:fix",
    "prepare": "husky",
    "telegram:webhook": "tsx --env-file=.env scripts/telegram/set-webhook.ts",
    "telegram:test-post": "tsx --env-file=.env scripts/telegram/test-post.ts",
    "telegram:autopost": "tsx --env-file=.env scripts/telegram/autopost.ts",
    "telegram:autopost:dry": "tsx --env-file=.env scripts/telegram/autopost.ts --dry-run",
    "telegram:baseline": "tsx --env-file=.env scripts/telegram/autopost.ts --baseline"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@vercel/analytics": "^2.0.1",
    "leaflet": "^1.9.4",
    "next": "16.1.6",
    "pg": "^8.18.0",
    "prisma": "^7.4.1",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
